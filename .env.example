MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-your-public-key
# Optional. Set it if you configure a Mercado Pago webhook signature secret.
MERCADOPAGO_WEBHOOK_SECRET=
# Local: http://localhost:3000
# Render: https://your-service.onrender.com or your custom domain.
# Do not leave this as localhost in Render.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render Postgres connection string. Render injects this automatically when
# created from render.yaml.
DATABASE_URL=postgresql://user:password@localhost:5432/fresh_bloom
# Set to true only when your Postgres provider requires TLS from this app.
DATABASE_SSL=false

# Admin access. Defaults in code are for local testing only.
ADMIN_USERNAME=FRESH_BLOOM
ADMIN_PASSWORD=FB_2026
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Use digits with country code, for example 529991234567.
BUSINESS_WHATSAPP_NUMBER=52XXXXXXXXXX
# Optional if you prefer to paste a full wa.me URL.
BUSINESS_WHATSAPP_URL=

# WhatsApp Cloud API credentials for automatic follow-up messages.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Pin the Graph API version used for Cloud API calls.
WHATSAPP_GRAPH_API_VERSION=v25.0
# Used when a customer enters a 10-digit local phone number.
WHATSAPP_DEFAULT_COUNTRY_CODE=52

# Webhook URL: https://your-domain.com/api/whatsapp/webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-this-verify-token
WHATSAPP_APP_SECRET=

# Approved WhatsApp templates. Confirmation should be Utility;
# promotions should be Marketing and require customer opt-in.
WHATSAPP_TEMPLATE_LANGUAGE=es_MX
WHATSAPP_CONFIRMATION_TEMPLATE_NAME=fresh_bloom_order_confirmed
WHATSAPP_CONFIRMATION_TEMPLATE_LANGUAGE=es_MX
WHATSAPP_PROMOTION_TEMPLATE_NAME=fresh_bloom_promotion
WHATSAPP_PROMOTION_TEMPLATE_LANGUAGE=es_MX
# Secret for POST /api/whatsapp/promotions.
WHATSAPP_PROMOTION_API_SECRET=change-this-random-secret
